# ========================================
# AI News Bot 配置文件
# ========================================
# 复制此文件为 app/.env 并填入实际配置
# 配置说明请参考 config.py 中的注释

# =============================================================================
# 第一部分：应用基础配置
# =============================================================================
APP_NAME=AI News Bot
APP_VERSION=1.0.0
DEBUG=false
# JWT 密钥，必填，长度不低于 32 字符
SECRET_KEY=your-secret-key-here-at-least-32-chars
# Access Token 有效期（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=15
# Refresh Token 有效期（天）
REFRESH_TOKEN_EXPIRE_DAYS=3

# =============================================================================
# 第二部分：数据库与存储配置
# =============================================================================
DATABASE_URL=sqlite+aiosqlite:///storage/database.db
REPORT_STORAGE_PATH=storage/reports

# =============================================================================
# 第三部分：LLM 配置
# =============================================================================
# LLM API 配置已迁移至数据库管理，请通过前端界面配置
# 仅保留本地 Ollama 配置（可选）

# Ollama 服务地址（如不配置则使用数据库中的 Provider）
# OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# =============================================================================
# 第四部分：GitHub 配置
# =============================================================================
# GitHub API Token（可选，增加请求频率限制）
GITHUB_TOKEN=
# 默认监控的 GitHub 语言（用 | 分隔）
DEFAULT_GITHUB_LANGUAGES=Python|JavaScript|TypeScript|Go

# =============================================================================
# 第五部分：企业微信配置（Agentic 对话功能）
# =============================================================================
# 企业微信自建应用配置，用于接收用户消息并回复
# 配置路径：企业微信后台 -> 应用管理 -> 自建应用
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_AGENT_SECRET=
WECOM_TOKEN=
WECOM_AES_KEY=

# =============================================================================
# 第六部分：Web 面板配置
# =============================================================================
WEB_PANEL_USERNAME=admin
WEB_PANEL_PASSWORD=your-password-here

# =============================================================================
# 第七部分：CORS 跨域配置
# =============================================================================
# 允许的跨域请求来源，多个用逗号分隔，生产环境应配置实际域名
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true

# =============================================================================
# 第八部分：定时任务调度配置
# =============================================================================
# --- 采集任务 ---
FETCH_AI_NEWS_INTERVAL=30       # AI 资讯 RSS 采集间隔（分钟）
PROCESS_PENDING_INTERVAL=20     # 待处理内容处理间隔（分钟）
FETCH_GITHUB_HOUR=22            # 每日 GitHub Trending 采集小时（0-23）
FETCH_WEEKLY_GITHUB_HOUR=7      # 每周 GitHub Trending 采集小时（0-23）

# --- 推送任务 ---
DAILY_REPORT_HOUR=23            # 日报推送小时（0-23）
DAILY_REPORT_MINUTE=40          # 日报推送分钟（0-59）
WEEKLY_REPORT_HOUR=8            # 周报推送小时（0-23）
WEEKLY_REPORT_DAY=0             # 周报推送日期（0=周一，6=周日）

# --- 清理任务 ---
CLEANUP_HOUR=3                  # 低分文章清理任务执行小时（0-23）
CLEANUP_EXPIRED_DATA_HOUR=4     # 过期数据清理任务执行小时（0-23）
# 超过此天数且评分比推送阈值低 20 分的文章会被清理
CLEANUP_DAYS_THRESHOLD_MIN=7
# 超过此天数且评分比推送阈值低 10 分的文章会被清理
CLEANUP_DAYS_THRESHOLD_MAX=30

# --- 向量任务 ---
CLUSTER_CRON_HOUR=3              # 每日主题聚类任务执行小时（0-23）
REINDEX_CRON_HOUR=4             # 每日向量对账任务执行小时（0-23）

# --- 定时任务公共配置 ---
DEFAULT_CRON_MINUTE=0           # 所有定时任务默认分钟数（0-59）

# =============================================================================
# 第九部分：推送与评分配置
# =============================================================================
# 只有评分 >= 此值的资讯才会立即推送，低于此值仅加入日报
PUSH_SCORE_THRESHOLD=85

# =============================================================================
# 第十部分：RSS 源配置
# =============================================================================
# 内置 RSS 源配置（用 | 分隔多个）
# 格式: name,url,category,source_type,is_active,fetch_interval
BUILTIN_RSS_SOURCES=Hacker News,https://news.ycombinator.com/rss,tech,builtin,true,60

RSS_CONCURRENT_LIMIT=5          # RSS 源并发采集数
RSS_ERROR_THRESHOLD=5           # RSS 源连续错误次数阈值，达到后自动禁用该源
RSS_FETCH_TIMEOUT=30.0         # 单个 RSS 源采集超时时间（秒）

# =============================================================================
# 第十一部分：内容处理配置
# =============================================================================
PROCESS_BATCH_SIZE=5            # 内容处理每批处理文章数
PROCESS_MAX_TOTAL=45            # 内容处理每次任务最多处理文章总数
PROCESS_BATCH_DELAY=2.0         # 内容处理批次间延迟秒数
ARTICLE_SAVE_BATCH_SIZE=100     # 文章批量保存每批最大数量

# =============================================================================
# 第十二部分：内容补全配置（Trafilatura 网页正文提取）
# =============================================================================
# 跳过补全的域名（用 | 分隔），这些域名在国内可能无法访问
TRAFILATURA_SKIP_DOMAINS=medium.com|news.ycombinator.com|bestblogs.dev|techcrunch.com|theverge.com
# 是否在 RSS 采集阶段同步补全文章内容（默认关闭，改为后台异步补全）
TRAFILATURA_ENABLE_IMMEDIATE_ENRICHMENT=false
ENRICH_CONCURRENCY=3            # 后台内容补全最大并发数
ENRICH_TIMEOUT=15.0            # 单篇文章内容补全超时时间（秒）
ENRICH_MIN_CONTENT_LENGTH=100  # 内容补全结果最小字符数

# =============================================================================
# 第十三部分：动态域名跳过配置
# =============================================================================
DYNAMIC_SKIP_ENABLED=true       # 是否启用动态域名跳过
DYNAMIC_SKIP_THRESHOLD=5        # 连续失败次数阈值，达到后自动跳过该域名

# =============================================================================
# 第十四部分：RSSHub 配置
# =============================================================================
RSSHUB_ENABLED=true             # 是否启用 RSSHub 集成
RSSHUB_URL=http://localhost:1200 # RSSHub 服务地址
RSSHUB_AUTO_START=true          # 是否在启动时自动启动 RSSHub（需 Docker）
RSSHUB_HEALTH_CHECK_INTERVAL=30 # RSSHub 健康检查间隔（秒）
RSSHUB_STARTUP_TIMEOUT=120      # RSSHub 启动等待超时时间（秒）
RSSHUB_ROUTES_FILE_PATH=storage/rsshub_build/routes.json
RSSHUB_ROUTES_STATIC_PATH=app/services/rsshub/routes_static.json

# =============================================================================
# 第十五部分：语义搜索与向量配置
# =============================================================================
SEMANTIC_CACHE_MAX_SESSIONS=100     # 语义搜索缓存最大会话数
SEMANTIC_CACHE_TTL_SECONDS=600      # 语义搜索缓存 TTL（秒）
SEMANTIC_SEARCH_MAX_RESULTS=100     # 语义搜索最大返回结果数
EMBEDDING_MAX_TEXT_LENGTH=4000     # Embedding 输入文本最大字符数
DEDUP_SIMILARITY_THRESHOLD=0.88    # 语义去重相似度阈值（0-1）
CACHE_SIMILARITY_THRESHOLD=0.85    # 语义缓存命中相似度阈值（0-1）

# --- 超时配置 ---
EMBEDDING_TIMEOUT=120.0           # Embedding 生成超时时间（秒）
LLM_API_TIMEOUT=30.0               # LLM API 调用测试超时时间（秒）
BATCH_LLM_TIMEOUT=120.0            # 批次 LLM 处理超时时间（秒）
WEBHOOK_API_TIMEOUT=10.0           # Webhook API 调用超时时间（秒）

# --- Embedding 服务地址配置 ---
OLLAMA_EMBEDDING_BASE_URL=http://localhost:11434  # Ollama Embedding 服务地址

# --- 企业微信超时配置 ---
WECOM_WEBHOOK_TIMEOUT=10.0         # 企业微信 Webhook 消息发送超时（秒）
WECOM_API_TIMEOUT=30.0             # 企业微信 API 调用超时（秒）
WECOM_UPLOAD_TIMEOUT=60.0          # 企业微信文件上传超时（秒）
WECOM_API_BASE_URL=https://qyapi.weixin.qq.com  # 企业微信 API 基础地址（需代理时修改）

# --- 重试配置 ---
LLM_MAX_RETRIES=3                  # LLM API 调用最大重试次数
EMBEDDING_MAX_RETRIES=3            # Embedding 生成最大重试次数

# --- 语义搜索配置 ---
SEMANTIC_SEARCH_TOP_K=5            # 语义搜索/去重返回的结果数量上限
SEMANTIC_CACHE_TOP_K=3             # 语义缓存查找结果数量

# --- GitHub API 配置 ---
GITHUB_API_BASE_URL=https://api.github.com  # GitHub API 基础地址

# --- 索引器配置 ---
INDEXER_CONCURRENCY=3               # 向量索引器并发处理数

# --- 命令配置 ---
COMMAND_DEFAULT_LIMIT=10             # 命令默认返回结果数
COMMAND_PREVIEW_LIMIT=5              # 命令预览结果数