# ========================================
# AI News Bot 配置文件
# ========================================
# 复制此文件为 app/.env 并填入实际配置

# ---------- 应用配置 ----------
APP_NAME=AI News Bot
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=your-secret-key-change-in-production

# ---------- 数据库配置 ----------
DATABASE_URL=sqlite+aiosqlite:///storage/database.db

# ---------- LLM 配置 ----------

# 本地LLM (用于摘要) - Ollama
# 如果不配置此项，将使用 OpenAI API 进行摘要
# 部署到服务器时建议不配置，使用API方式
# OLLAMA_BASE_URL=
# OLLAMA_MODEL=llama3

# OpenAI API (用于摘要和评分)
# ========================================
# 支持的API供应商:
# - OpenAI: https://api.openai.com/v1
# - 阿里云DashScope: https://dashscope.aliyuncs.com/compatible-mode/v1
# - Anthropic (Claude): https://api.anthropic.com/v1
# - 硅基流动: https://api.siliconflow.cn/v1
# - 其他兼容OpenAI格式的API
# ========================================

OPENAI_API_KEY=sk-your-openai-api-key

# API地址 - 根据你使用的服务商修改
OPENAI_API_BASE=https://api.openai.com/v1

# ---------- 模型配置 ----------
# 摘要使用的模型 (推荐使用便宜快速的模型)
# 推荐: gpt-4o-mini, qwen-turbo, glm-4-flash, deepseek-chat
OPENAI_SUMMARY_MODEL=gpt-4o-mini

# 评分使用的模型 (可以使用稍好一些的模型)
# 推荐: gpt-4o-mini, qwen-plus, glm-4-plus
OPENAI_SCORE_MODEL=gpt-4o-mini

# ---------- GitHub 配置 ----------
# GitHub API Token (可选，增加请求限制)
GITHUB_TOKEN=

# ---------- 消息推送 ----------

# 企业微信 Webhook (群机器人 - 仅推送)
WECOM_WEBHOOK_KEY=your-wecom-webhook-key

# 企业微信自建应用 (双向交互)
WECOM_CORP_ID=your-corp-id
WECOM_AGENT_ID=your-agent-id
WECOM_AGENT_SECRET=your-agent-secret
WECOM_TOKEN=your-token
WECOM_AES_KEY=your-encoding-aes-key

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------- 定时任务配置 ----------

# 采集任务时间 (小时, 24小时制)
FETCH_NEWS_HOUR=6
FETCH_GITHUB_HOUR=7

# 推送时间
DAILY_REPORT_HOUR=8
WEEKLY_REPORT_HOUR=9
WEEKLY_REPORT_DAY=0  # 0=周一, 6=周日

# ---------- 评分阈值 ----------
# 只有评分>=此值的资讯才会立即推送
PUSH_SCORE_THRESHOLD=8

# ---------- 采集源配置 ----------

# 默认RSS订阅源 (用|分隔多个)
DEFAULT_RSS_SOURCES=|
    https://openai.com/blog/rss.xml|
    https://news.ycombinator.com/rss|

# 默认GitHub语言
DEFAULT_GITHUB_LANGUAGES=Python|JavaScript|TypeScript|Go
